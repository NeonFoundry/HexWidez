<Window x:Class="HexWide.FilePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FontSize="20"
        FontFamily="pack://application:,,,/Assets/Fonts/#VT323"
        Title="Select File" Height="520" Width="820" WindowStartupLocation="CenterOwner"
        Background="#000000" WindowStyle="ToolWindow">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="393*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <TextBox x:Name="txtCurrentPath" IsReadOnly="True" Background="#000000" Foreground="#FF06B5" BorderBrush="#F9F002"/>
            <Button Content="Up" Margin="8,0,0,0" Click="UpButton_Click" Background="#F9F002"/>
        </StackPanel>

        <Grid Margin="0,26,0,26" Grid.RowSpan="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#000000" BorderBrush="#FF06B5" BorderThickness="1" CornerRadius="6" Padding="6">
                <TreeView x:Name="folderTree" SelectedItemChanged="FolderTree_SelectedItemChanged" Background="#FFFFFF" Foreground="#FF06B5"/>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" ShowsPreview="True"/>

            <Border Grid.Column="2" Background="#000000" BorderBrush="#FF06B5" BorderThickness="1" CornerRadius="6" Padding="6">
                <ListView x:Name="fileList" MouseDoubleClick="FileList_MouseDoubleClick" Background="#000000" Foreground="#FF06B5">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="420"/>
                            <GridViewColumn Header="Size" DisplayMemberBinding="{Binding SizeText}" Width="100"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Width="96" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Open" Width="96" Click="Open_Click" Background="#F9F002"/>
        </StackPanel>
    </Grid>
</Window>
