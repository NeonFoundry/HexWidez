<Window x:Class="HexWide.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wc="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:HexWide"
    mc:Ignorable="d"
    Title="HexWide | Widescreen Patcher"
    Icon="Assets/HxW.ico"
    MinHeight="620"
    MinWidth="920"
    WindowStartupLocation="CenterScreen"
    Background="#070207"
    FontFamily="pack://application:,,,/Assets/Fonts/#VT323"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStyle="None"
    AllowsTransparency="False"
    ResizeMode="CanResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF06B5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#17020F"/>
            <Setter Property="Foreground" Value="#FFF7AC"/>
            <Setter Property="BorderBrush" Value="#FF06B5"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#17020F"/>
            <Setter Property="Foreground" Value="#FF06B5"/>
            <Setter Property="BorderBrush" Value="#FF06B5"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#000000"/>
            <Setter Property="Foreground" Value="#FF06B5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#190015"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A001F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <local:WidthToFontSizeConverter x:Key="WidthToFontSizeConverter"/>
        
        <Style x:Key="ResponsiveTitleTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WidthToFontSizeConverter}, ConverterParameter=34}"/>
        </Style>
        <Style x:Key="ResponsiveSectionHeaderTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WidthToFontSizeConverter}, ConverterParameter=22}"/>
        </Style>
        <Style x:Key="ResponsiveBodyTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WidthToFontSizeConverter}, ConverterParameter=18}"/>
            <Setter Property="Foreground" Value="#FFF7AC"/>
        </Style>
        <Style x:Key="ResponsiveLabelTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WidthToFontSizeConverter}, ConverterParameter=18}"/>
            <Setter Property="Foreground" Value="#FF06B5"/>
        </Style>
        <Style x:Key="ResponsiveCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WidthToFontSizeConverter}, ConverterParameter=8}"/>
            <Setter Property="Foreground" Value="#FFF7AC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResponsiveCaptionTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WidthToFontSizeConverter}, ConverterParameter=8}"/>
        </Style>
        <Style x:Key="ResponsiveStatusMessage" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WidthToFontSizeConverter}, ConverterParameter=15}"/>
        </Style>
        <Style x:Key="ResponsiveButton" TargetType="Button">
            <Setter Property="FontSize" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WidthToFontSizeConverter}, ConverterParameter=13}"/>
            <Setter Property="Foreground" Value="#13010C"/>
            <Setter Property="Background" Value="#FF06B5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}" BorderThickness="1" BorderBrush="#FF06B5" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE96B"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#13010C"/>
            <Setter Property="Background" Value="#FF06B5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}" BorderThickness="1" BorderBrush="#FF06B5" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Caption button style with hover glow -->
        <Style x:Key="CaptionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#ff06b5"/>
            <Setter Property="BorderBrush" Value="#ff06b5"/>
            <Setter Property="Effect" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFF1"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF06B5" BlurRadius="18" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF06B5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TechSettingsButtonStyle"
       TargetType="Button"
       BasedOn="{StaticResource CaptionButtonStyle}">

            <Setter Property="Foreground" Value="#00F7FF"/>
            <Setter Property="Background" Value="#080014"/>
            <Setter Property="BorderBrush" Value="#00F7FF"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1.5"
                        Padding="4"
                        CornerRadius="2">

                            <Border.Effect>
                                <DropShadowEffect x:Name="Glow"
                                          Color="#00F7FF"
                                          BlurRadius="14"
                                          ShadowDepth="0"
                                          Opacity="0.65"/>
                            </Border.Effect>

                            <Grid RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform x:Name="IconRotate" Angle="0"/>
                                </Grid.RenderTransform>

                                <TextBlock Text="⛭"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="#00F7FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever"
                                        AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="Glow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.35"
                                                 To="0.95"
                                                 Duration="0:0:1.2"/>
                                        <DoubleAnimation Storyboard.TargetName="Glow"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 From="8"
                                                 To="20"
                                                 Duration="0:0:1.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#001C24"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF06B5"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#00F7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <wc:WindowChrome.WindowChrome>
        <wc:WindowChrome CaptionHeight="44" ResizeBorderThickness="6" CornerRadius="12" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </wc:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <Grid.Background>
            <SolidColorBrush Color="#000000"/>
        </Grid.Background>
        <Border Grid.Row="1" Margin="24" Background="#000000" BorderBrush="#F9F002" BorderThickness="1.4" Opacity="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="36,12,24,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="HEXWIDE" Style="{StaticResource ResponsiveTitleTextBlock}" FontWeight="Bold" />
                        <TextBlock Grid.Row="1" Text="Ultrawide resolution patcher" Style="{StaticResource ResponsiveSectionHeaderTextBlock}" Margin="0,6,0,16"/>
                        <TextBlock Grid.Row="2" Text="Select a compatible executable, choose an aspect ratio, and patch it with an automatic backup created beforehand." TextWrapping="Wrap" Style="{StaticResource ResponsiveBodyTextBlock}" Margin="0,0,0,24"/>

                        <Border Grid.Row="3" Background="#000000" BorderBrush="#FF06B5" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                            <StackPanel>

                                <TextBlock Text="• Automatic backup before patching" Style="{StaticResource ResponsiveBodyTextBlock}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="• Optional FOV compensation" Style="{StaticResource ResponsiveBodyTextBlock}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4" Background="#000000" BorderBrush="#F9F002" BorderThickness="1" Padding="16" Opacity="1" VerticalAlignment="Bottom">
                            <StackPanel>
                                <TextBlock Text="The patcher is intended to work with executables and not configuration files" Style="{StaticResource ResponsiveLabelTextBlock}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Column="1" Margin="0,12,24,12" Background="#000000" BorderBrush="#FF06B5" BorderThickness="1.2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Patch configuration" Style="{StaticResource ResponsiveSectionHeaderTextBlock}" FontWeight="SemiBold" Margin="0,0,0,18"/>

                            <TextBlock Grid.Row="1" Text="Target executable" Style="{StaticResource ResponsiveLabelTextBlock}" Margin="0,0,0,6"/>
                            <Grid Grid.Row="2" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtPath" Grid.Column="0"/>
                                <Button Grid.Column="1" Content="Browse" MinWidth="120" Margin="8,0,0,12"  Style="{StaticResource ResponsiveButton}" Click="BrowseButton_Click"/>
                            </Grid>

                            <TextBlock Grid.Row="3" Text="Resolution" Style="{StaticResource ResponsiveLabelTextBlock}" Margin="0,0,0,6"/>

                            <ComboBox Grid.Row="4"
                                x:Name="comboResolutions"
                                Height="55"
                                FontFamily="Consolas"
                                FontSize="40"
                                FontWeight="SemiBold"
                                Foreground="#FF06B5"
                                Background="#111111"
                                BorderBrush="#FF06B5"
                                BorderThickness="2"
                                Padding="8,4"
                            />
                            
                            <StackPanel Grid.Row="5" VerticalAlignment="Bottom">
                                <CheckBox
                                    x:Name="chkFovFix"
                                    Content="Apply FOV compensation"
                                    Style="{StaticResource ResponsiveCheckBox}" 
                                    />
                                <Button Content="Patch executable" Click="ApplyButton_Click" Style="{StaticResource ResponsiveButton}" Margin="0,8,0,0"/>

                                <Border Margin="0,18,0,0" Background="#000000" BorderBrush="#F9F002" BorderThickness="1" Padding="12">
                                    <StackPanel>
                                        <TextBlock x:Name="statusMessage" Style="{StaticResource ResponsiveStatusMessage}" Text="> Select an executable to get started" TextWrapping="Wrap"/>
                                        <ProgressBar x:Name="patchProgressBar" Height="8" Margin="0,10,0,6" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"/>
                                        <TextBlock x:Name="progressLabel" Text="" Margin="0,2,0,0" Foreground="#FFE96B" Visibility="Collapsed"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- Yellow footer -->
        <Border Grid.Row="2" Background="#F9F002" Panel.ZIndex="90" RenderTransformOrigin="0.5,0.5" Margin="27,0,29,0">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleX="0.716"/>
                        <RotateTransform/>
                        <TranslateTransform X="-0.488"/>
                    </TransformGroup>
                </Border.RenderTransform>

            <TextBlock FontFamily="Consolas" Foreground="#FF06B5" Style="{StaticResource ResponsiveCaptionTextBlock}" HorizontalAlignment="Left" VerticalAlignment="Center" TextAlignment="Center" xml:space="preserve" Margin="30,0,0,0">LIGHTER THAN AIR SOFTWARE</TextBlock>
            </Border>

            <!-- Custom title bar (Windows 11 style) placed last so property elements remain valid -->
            <Grid Grid.Row="0" x:Name="TitleBar" VerticalAlignment="Stretch" Margin="28,0,0,0" PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="#F9F002" Panel.ZIndex="100" Cursor="Arrow">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="HEXWIDE" Style="{StaticResource ResponsiveLabelTextBlock}" FontWeight="Bold" Foreground="#13010C" Margin="6,0"/>
                    <TextBlock Text=" | Widescreen Patcher" Style="{StaticResource ResponsiveCaptionTextBlock}" Foreground="#13010C" Margin="8,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,28,0">
                    <!--<Button x:Name="SettingsButton" Style="{StaticResource CaptionButtonStyle}" Margin="4,0,4,0" Click="SettingsButton_Click" ToolTip="Settings" wc:WindowChrome.IsHitTestVisibleInChrome="True">-->
                <Button x:Name="SettingsButton" Style="{StaticResource TechSettingsButtonStyle}" Margin="4,0,4,0" Click="SettingsButton_Click" ToolTip="Settings" wc:WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="⚙" Foreground="#000000" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButtonStyle}" Margin="4,0,4,0" Click="MinimizeButton_Click" ToolTip="Minimize" wc:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Data="M 0 6 L 12 6" Stroke="#13010C" StrokeThickness="2" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButtonStyle}" Margin="4,0,4,0" Click="MaximizeButton_Click" ToolTip="Maximize/Restore" wc:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Grid>
                            <Rectangle Width="12" Height="10" Stroke="#13010C" StrokeThickness="2"/>
                        </Grid>
                    </Button>
                <Button x:Name="CloseButton" Style="{StaticResource CaptionButtonStyle}" Margin="4,0,4,0" Click="CloseButton_Click" ToolTip="Close" wc:WindowChrome.IsHitTestVisibleInChrome="True" RenderTransformOrigin="0.386,-0.433">
                        <Path Data="M 2 2 L 10 10 M 10 2 L 2 10" Stroke="#13010C" StrokeThickness="2" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
</Window>
